{
  "name": "@detent/healer",
  "version": "0.1.1",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "build": "bun build src/index.ts --outdir dist --target bun",
    "start": "bun run dist/index.js",
    "queue:smoke": "bun run src/queue-smoke.ts",
    "check-types": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@detent/healing": "*",
    "@detent/sandbox": "*",
    "@detent/types": "*",
    "drizzle-orm": "^0.41.0",
    "hono": "^4.7.4",
    "jose": "^6.0.10",
    "pg": "^8.13.0",
    "zod": "^3.25.34"
  },
  "devDependencies": {
    "@detent/typescript-config": "*",
    "@types/node": "^25.0.3",
    "@types/pg": "^8.11.6",
    "typescript": "5.9.2",
    "vitest": "^4.0.16"
  }
}
