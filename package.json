{
  "name": "detent",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "build:api": "turbo run build --filter=@detent/api",
    "build:cli": "turbo run build --filter=@detent/cli",
    "dev": "turbo run dev",
    "dev:core": "turbo run dev --filter=@detent/api --filter=@detent/web --filter=@detent/navigator",
    "lint": "ultracite check",
    "fix": "ultracite fix",
    "check-types": "turbo run check-types",
    "test": "turbo run test",
    "prepare": "[ -d .git ] && lefthook install || true",
    "dt": "bun run apps/cli/dist/index.js"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.11",
    "lefthook": "^2.0.13",
    "lint-staged": "^16.2.7",
    "turbo": "^2.8.3",
    "typescript": "^5.9.3",
    "ultracite": "7.0.11",
    "wrangler": "^4.60.0"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "bun@1.3.5",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "lint-staged": {
    "*.{js,jsx,ts,tsx,json,jsonc,css,scss,md,mdx}": [
      "bun x ultracite fix",
      "bun x ultracite fix"
    ]
  },
  "dependencies": {
    "@handleui/shimmer": "0.1.0",
    "convex": "^1.31.7",
    "motion": "^12.34.0",
    "tar": "^7.5.6"
  }
}
