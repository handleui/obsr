{
  "name": "@obsr/sentry",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./scrub": {
      "types": "./dist/scrub.d.ts",
      "default": "./dist/scrub.js"
    },
    "./headers": {
      "types": "./dist/headers.d.ts",
      "default": "./dist/headers.js"
    },
    "./event": {
      "types": "./dist/event.d.ts",
      "default": "./dist/event.js"
    },
    "./types": {
      "types": "./dist/types.d.ts",
      "default": "./dist/types.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "check-types": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@obsr/typescript-config": "*",
    "@types/node": "^25.0.3",
    "typescript": "^5.9.3",
    "vitest": "^4.0.16"
  }
}
