# Healer service required environment variables

# Convex deployment URL
CONVEX_URL=
CONVEX_SERVICE_TOKEN=

# Sandbox provider (vercel | e2b)
# If vercel: requires VERCEL_* values
# If e2b: requires E2B_API_KEY
SANDBOX_PROVIDER=vercel
E2B_API_KEY=
VERCEL_TOKEN=
VERCEL_TEAM_ID=
VERCEL_PROJECT_ID=

# Vercel AI Gateway API key
AI_GATEWAY_API_KEY=

# GitHub App credentials (for installation token access)
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
