# Local development environment variables
# Copy to .dev.vars and fill in your values
# These mirror the secrets set in Cloudflare dashboard

GITHUB_APP_ID=your_app_id
GITHUB_CLIENT_ID=your_client_id
# GitHub App Client Secret (for OAuth token refresh) - found in GitHub App settings
GITHUB_CLIENT_SECRET=your_client_secret
# IMPORTANT: Private key must be single-line with literal \n (dotenv doesn't support multiline)
# Convert with: awk 'NF {sub(/\r/, ""); printf "%s\\n",$0;}' your-key.pem
GITHUB_APP_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nMIIE...\n...\n-----END RSA PRIVATE KEY-----"
GITHUB_WEBHOOK_SECRET=your_webhook_secret

# WorkOS User Management credentials
WORKOS_CLIENT_ID=your_workos_client_id
WORKOS_API_KEY=your_workos_api_key

# Neon database (dev branch, direct connection)
DATABASE_URL=postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/dbname?sslmode=require
WRANGLER_HYPERDRIVE_LOCAL_CONNECTION_STRING_HYPERDRIVE=postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/dbname?sslmode=require

# Upstash Redis for rate limiting
UPSTASH_REDIS_REST_URL=your_upstash_url
UPSTASH_REDIS_REST_TOKEN=your_upstash_token

# Sandbox provider (vercel | e2b)
SANDBOX_PROVIDER=vercel
# E2B sandbox API key (required when SANDBOX_PROVIDER=e2b)
E2B_API_KEY=
# Vercel Sandbox auth (use OIDC when deployed on Vercel)
VERCEL_OIDC_TOKEN=
# Or use access token + team/project IDs when OIDC is unavailable
VERCEL_TOKEN=
VERCEL_TEAM_ID=
VERCEL_PROJECT_ID=

# Email (Resend) configuration
RESEND_API_KEY=your_resend_api_key
RESEND_EMAIL_FROM="Detent <noreply@detent.dev>"

# Navigator (web app) base URL for invitation links
NAVIGATOR_BASE_URL=http://localhost:3000

# Modal executor webhook secret (HMAC signature verification)
MODAL_WEBHOOK_SECRET=your_modal_webhook_secret
