{
  "name": "@detent/diagnostics",
  "version": "1.1.0",
  "type": "module",
  "description": "Parse CI tool output into structured diagnostics",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/detentsh/detent",
    "directory": "packages/diagnostics"
  },
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "import": "./dist/client.js",
      "default": "./dist/client.js"
    },
    "./types": {
      "types": "./dist/types.d.ts",
      "import": "./dist/types.js",
      "default": "./dist/types.js"
    },
    "./detect": {
      "types": "./dist/detect.d.ts",
      "import": "./dist/detect.js",
      "default": "./dist/detect.js"
    },
    "./parsers/eslint": {
      "types": "./dist/parsers/eslint.d.ts",
      "import": "./dist/parsers/eslint.js",
      "default": "./dist/parsers/eslint.js"
    },
    "./parsers/typescript": {
      "types": "./dist/parsers/typescript.d.ts",
      "import": "./dist/parsers/typescript.js",
      "default": "./dist/parsers/typescript.js"
    },
    "./parsers/vitest": {
      "types": "./dist/parsers/vitest.d.ts",
      "import": "./dist/parsers/vitest.js",
      "default": "./dist/parsers/vitest.js"
    },
    "./parsers/cargo": {
      "types": "./dist/parsers/cargo.d.ts",
      "import": "./dist/parsers/cargo.js",
      "default": "./dist/parsers/cargo.js"
    },
    "./parsers/golangci": {
      "types": "./dist/parsers/golangci.d.ts",
      "import": "./dist/parsers/golangci.js",
      "default": "./dist/parsers/golangci.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "ci",
    "diagnostics",
    "eslint",
    "typescript",
    "vitest",
    "cargo",
    "parser"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "check-types": "tsc --noEmit"
  },
  "devDependencies": {
    "@detent/typescript-config": "*",
    "@types/node": "^22.0.0",
    "typescript": "5.9.2"
  }
}
