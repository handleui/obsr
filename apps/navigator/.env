# Navigator (web app) environment variables
# Copy to .env.development and fill in your values

# WorkOS User Management credentials
WORKOS_CLIENT_ID=client_xxx
WORKOS_API_KEY=sk_test_xxx
WORKOS_COOKIE_PASSWORD=replace_with_secure_password

# JWT secret for session tokens
# Generate with: openssl rand -base64 32
JWT_SECRET_KEY=replace_with_generated_secret

# App URL (this app's public URL)
# Used for OAuth redirect URIs
NEXT_PUBLIC_APP_URL=http://localhost:3001

# API URL (Detent API)
# Used for server-side API calls (e.g., invitation acceptance)
NEXT_PUBLIC_API_URL=http://localhost:8787

# Billing (Polar)
# POLAR_ACCESS_TOKEN is used by API, Navigator uses POLAR_CHECKOUT_TOKEN
POLAR_CHECKOUT_TOKEN=
NEXT_PUBLIC_POLAR_PRODUCT_ID=replace_with_product_id

# Optional: Sentry error monitoring
# NEXT_PUBLIC_SENTRY_DSN=