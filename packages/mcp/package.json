{
  "name": "@detent/mcp",
  "version": "0.1.0",
  "type": "module",
  "description": "MCP server for Detent - AI-powered CI/CD diagnostics and healing",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/detentsh/detent",
    "directory": "packages/mcp"
  },
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "detent-mcp": "./dist/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "detent",
    "mcp",
    "model-context-protocol",
    "ai",
    "ci",
    "cd"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "check-types": "tsc --noEmit",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "@detent/sdk": "*",
    "@modelcontextprotocol/sdk": "^1.25.3",
    "zod": "^3.25.42"
  },
  "devDependencies": {
    "@detent/typescript-config": "*",
    "@types/node": "^22.0.0",
    "typescript": "5.9.2"
  }
}
