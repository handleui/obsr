{
  "name": "obsr",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "build:docs": "turbo run build --filter=@obsr/docs",
    "build:obsr": "turbo run build --filter=@obsr/obsr",
    "build:cli": "turbo run build --filter=@obsr/cli",
    "dev": "turbo run dev",
    "dev:docs": "turbo run dev --filter=@obsr/docs",
    "dev:obsr": "turbo run dev --filter=@obsr/obsr",
    "lint": "ultracite check",
    "fix": "ultracite fix",
    "check-types": "turbo run check-types",
    "check:legacy-imports": "bash ./scripts/check-no-legacy-imports.sh",
    "test": "turbo run test",
    "prepare": "[ -d .git ] && lefthook install || true",
    "dt": "bun ./apps/cli/src/index.ts"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.11",
    "lefthook": "^2.0.13",
    "lint-staged": "^16.2.7",
    "turbo": "^2.8.10",
    "typescript": "^5.9.3",
    "ultracite": "7.0.11",
    "wrangler": "^4.60.0"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "bun@1.3.5",
  "workspaces": [
    "apps/*",
    "packages/ai",
    "packages/issues",
    "packages/types",
    "packages/typescript-config",
    "packages/ui"
  ],
  "lint-staged": {
    "*.{js,jsx,ts,tsx,json,jsonc,css,scss,md,mdx}": [
      "bun x ultracite fix",
      "bun x ultracite fix"
    ]
  },
  "dependencies": {
    "@handleui/shimmer": "0.1.0",
    "motion": "^12.34.0",
    "tar": "^7.5.6"
  }
}
