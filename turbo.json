{
  "$schema": "https://v2-8-1.turborepo.dev/schema.json",
  "ui": "tui",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"],
      "env": [
        "JWT_SECRET_KEY",
        "BETTER_AUTH_SECRET",
        "BETTER_AUTH_URL",
        "BETTER_AUTH_GITHUB_CLIENT_ID",
        "BETTER_AUTH_GITHUB_CLIENT_SECRET",
        "BETTER_AUTH_DEVICE_CLIENT_IDS",
        "BETTER_AUTH_DEVICE_VERIFICATION_URI",
        "POLAR_CHECKOUT_TOKEN",
        "DATABASE_URL"
      ]
    },
    "@obsr/cli#build": {
      "inputs": [
        "src/**/*.ts",
        "src/templates/**",
        "tsconfig.json",
        "package.json"
      ],
      "outputs": ["dist/**"]
    },
    "@obsr/docs#build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$"],
      "outputs": [".next/**", "!.next/cache/**"],
      "env": ["BLOB_READ_WRITE_TOKEN"]
    },
    "@obsr/obsr#build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$"],
      "outputs": [".next/**", "!.next/cache/**"],
      "env": ["AI_GATEWAY_API_KEY", "OBSR_DATABASE_URL"]
    },
    "check-types": {
      "dependsOn": ["^build"]
    },
    "test": {
      "dependsOn": ["^build"]
    },
    "dev": {
      "dependsOn": ["^build"],
      "cache": false,
      "persistent": true
    }
  }
}
