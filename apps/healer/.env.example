# Healer service environment variables

# Convex
CONVEX_URL=https://your-deployment.convex.cloud
CONVEX_SERVICE_TOKEN=

# Neon PostgreSQL
DATABASE_URL=postgresql://user:pass@host/neondb?sslmode=require

# GitHub App
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=

# AI Gateway
AI_GATEWAY_API_KEY=

# Sandbox (e2b or vercel)
SANDBOX_PROVIDER=e2b
E2B_API_KEY=

# Navigator URL (for heal result links)
NAVIGATOR_BASE_URL=http://localhost:3001
