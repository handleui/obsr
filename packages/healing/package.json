{
  "name": "@detent/healing",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./tools": "./src/tools/index.ts",
    "./prompt": "./src/prompt/index.ts",
    "./prompt/system": "./src/prompt/system.ts",
    "./prompt/format": "./src/prompt/format.ts",
    "./eval": "./src/eval/index.ts"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "check-types": "tsc --noEmit",
    "eval": "bun run src/eval/run.ts",
    "eval:live": "EVAL_MODE=live bun run src/eval/run.ts"
  },
  "dependencies": {
    "@detent/lore": "workspace:*",
    "@detent/types": "workspace:*",
    "ai": "^5.0.0",
    "fast-glob": "^3.3.3",
    "zod": "^3.25.34"
  },
  "devDependencies": {
    "@detent/typescript-config": "*",
    "@types/node": "^22.15.3",
    "autoevals": "^0.0.131",
    "braintrust": "^2.0.0",
    "typescript": "^5.9.3"
  }
}
