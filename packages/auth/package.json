{
  "name": "@detent/auth",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "build": "tsc",
    "check-types": "tsc --noEmit",
    "auth:generate": "bunx @better-auth/cli@latest generate --config ./src/auth.ts",
    "auth:migrate": "bunx @better-auth/cli@latest migrate --config ./src/auth.ts"
  },
  "dependencies": {
    "@better-auth/api-key": "^1.5.3",
    "@better-auth/drizzle-adapter": "^1.5.3",
    "@detent/db": "*",
    "better-auth": "^1.5.3",
    "drizzle-orm": "^0.44.0"
  },
  "devDependencies": {
    "@detent/typescript-config": "*",
    "typescript": "^5.9.3"
  }
}
