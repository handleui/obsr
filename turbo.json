{
  "$schema": "https://v2-8-1.turborepo.dev/schema.json",
  "ui": "tui",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"],
      "env": [
        "WORKOS_CLIENT_ID",
        "JWT_SECRET_KEY",
        "WORKOS_COOKIE_PASSWORD",
        "WORKOS_API_KEY",
        "POLAR_CHECKOUT_TOKEN",
        "CONVEX_URL",
        "DATABASE_URL"
      ]
    },
    "@detent/cli#build": {
      "dependsOn": ["@detent/resolving#build", "@detent/git#build"],
      "inputs": [
        "src/**/*.ts",
        "src/**/*.tsx",
        "tsconfig.json",
        "package.json"
      ],
      "outputs": ["dist/**"]
    },
    "@detent/observer#build": {
      "dependsOn": ["@detent/db#build", "^build"],
      "inputs": ["src/**", "wrangler.jsonc", "tsconfig.json", "package.json"],
      "outputs": ["dist/**"]
    },
    "@detent/resolver#build": {
      "dependsOn": [
        "@detent/db#build",
        "@detent/resolving#build",
        "@detent/sandbox#build"
      ],
      "inputs": ["src/**/*.ts", "tsconfig.json", "package.json"],
      "outputs": ["dist/**"]
    },
    "@detent/web#build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$"],
      "outputs": [".next/**", "!.next/cache/**"],
      "env": ["BLOB_READ_WRITE_TOKEN"]
    },
    "check-types": {
      "dependsOn": ["^build"]
    },
    "test": {
      "dependsOn": ["^build"]
    },
    "dev": {
      "dependsOn": ["^build"],
      "cache": false,
      "persistent": true
    }
  }
}
