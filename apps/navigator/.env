# Navigator (web app) environment variables

# WorkOS
WORKOS_CLIENT_ID=client_xxx
WORKOS_API_KEY=sk_test_xxx
WORKOS_COOKIE_PASSWORD=replace_with_secure_password

# Convex
CONVEX_URL=https://your-deployment.convex.cloud
CONVEX_SERVICE_TOKEN=

# JWT (generate with: openssl rand -base64 32)
JWT_SECRET_KEY=replace_with_generated_secret

# Neon PostgreSQL
NEON_DATABASE_URL=postgresql://user:pass@host/neondb?sslmode=require

# URLs
NEXT_PUBLIC_APP_URL=http://localhost:3001
NEXT_PUBLIC_API_URL=http://localhost:8787

# Billing (Polar)
POLAR_CHECKOUT_TOKEN=
NEXT_PUBLIC_POLAR_PRODUCT_ID=replace_with_product_id

# Vercel Flags
# FLAGS: SDK key (vf_...) from Vercel Dashboard (Project Settings > Flags)
# FLAGS_SECRET: generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
# Add real values to .env.development
