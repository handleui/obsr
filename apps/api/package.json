{
  "name": "@detent/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "dev:tunnel": "hookdeck listen 8787 github-app --path /webhooks/github --output compact",
    "build": "wrangler deploy --dry-run --outdir=dist",
    "deploy": "wrangler deploy --minify",
    "check-types": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "cf-typegen": "wrangler types --env-interface CloudflareBindings",
    "email:dev": "email dev --dir src/emails --port 3003"
  },
  "dependencies": {
    "@detent/ai": "*",
    "@detent/db": "*",
    "@detent/extract": "*",
    "@detent/healing": "*",
    "@detent/lore": "*",
    "@detent/sentry": "workspace:*",
    "@detent/sandbox": "*",
    "@detent/types": "*",
    "@hono/zod-openapi": "^1.2.0",
    "@polar-sh/sdk": "^0.42.2",
    "@react-email/components": "^0.0.34",
    "@sentry/cloudflare": "^10.32.1",
    "@upstash/ratelimit": "^2.0.7",
    "@upstash/redis": "^1.36.0",
    "convex": "^1.31.7",
    "fflate": "^0.8.2",
    "hono": "^4.11.3",
    "jose": "^6.0.10",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "resend": "^6.7.0",
    "sealed-box": "^0.1.0",
    "tweetnacl": "^1.0.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250106.0",
    "@e2b/code-interpreter": "^2.3.3",
    "@types/node": "^25.0.3",
    "@types/react": "^18.3.3",
    "dotenv": "^17.2.3",
    "react-email": "^3.0.4",
    "typescript": "^5.9.3",
    "vitest": "^4.0.16",
    "wrangler": "^4.4.0"
  }
}
