# HTTP port for the healer service
PORT=8080

# Database connection (same Postgres used by API)
DATABASE_URL=postgres://user:password@host:5432/detent

# Sandbox provider (vercel | e2b, default: vercel)
SANDBOX_PROVIDER=vercel

# E2B sandbox API key (required only if SANDBOX_PROVIDER=e2b)
E2B_API_KEY=

# Vercel Sandbox auth (required if SANDBOX_PROVIDER=vercel)
# Use OIDC token when deployed on Vercel
VERCEL_OIDC_TOKEN=
# Or use access token + team/project IDs when OIDC is unavailable
VERCEL_TOKEN=
VERCEL_TEAM_ID=
VERCEL_PROJECT_ID=

# Vercel AI Gateway API key
AI_GATEWAY_API_KEY=

# GitHub App credentials (for installation token access)
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
