# Local development environment variables
# Copy to .dev.vars and fill in your values
# These mirror the secrets set in Cloudflare dashboard

GITHUB_APP_ID=your_app_id
GITHUB_CLIENT_ID=your_client_id
GITHUB_APP_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----
your_private_key_here
-----END RSA PRIVATE KEY-----"
GITHUB_WEBHOOK_SECRET=your_webhook_secret

# WorkOS User Management credentials
WORKOS_CLIENT_ID=your_workos_client_id
WORKOS_API_KEY=your_workos_api_key

# Local Postgres for development (run: docker compose up -d)
# For production migrations, override: DATABASE_URL="postgresql://..." bun run db:push
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/detent

# Upstash Redis for rate limiting
UPSTASH_REDIS_REST_URL=your_upstash_url
UPSTASH_REDIS_REST_TOKEN=your_upstash_token

# Email (Resend) configuration
RESEND_API_KEY=your_resend_api_key
RESEND_EMAIL_FROM="Detent <noreply@detent.dev>"

# Navigator (web app) base URL for invitation links
NAVIGATOR_BASE_URL=http://localhost:3000
