# Observer (Cloudflare Workers) environment variables
# Copy to .dev.vars and fill in your values

# GitHub App
GITHUB_APP_ID=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
# Private key must be single-line with literal \n
# Convert: awk 'NF {sub(/\r/, ""); printf "%s\\n",$0;}' your-key.pem
GITHUB_APP_PRIVATE_KEY=
GITHUB_WEBHOOK_SECRET=

# Better Auth
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://observer.localhost:1355
BETTER_AUTH_TRUSTED_ORIGINS=http://detent.localhost:1355
BETTER_AUTH_GITHUB_CLIENT_ID=
BETTER_AUTH_GITHUB_CLIENT_SECRET=

# Neon PostgreSQL (local dev)
DATABASE_URL=postgresql://user:pass@host/neondb?sslmode=require

# Upstash Redis (rate limiting)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Resend (email)
RESEND_API_KEY=
RESEND_EMAIL_FROM="Detent <noreply@detent.dev>"

# App URLs and CORS
APP_BASE_URL=http://detent.localhost:1355
ALLOWED_ORIGINS=http://detent.localhost:1355

# Encryption for stored third-party secrets
ENCRYPTION_KEY=

# AI Gateway
AI_GATEWAY_API_KEY=

# Upstash QStash (resolver queue)
UPSTASH_QSTASH_URL=https://qstash.upstash.io
UPSTASH_QSTASH_TOKEN=
RESOLVER_WEBHOOK_URL=https://resolver.detent.sh/queue/resolves
