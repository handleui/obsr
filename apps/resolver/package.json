{
  "name": "@obsr/resolver",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "dev": "portless resolver bun run --watch src/index.ts",
    "build": "bun build src/index.ts --outdir dist --target bun",
    "start": "bun run dist/index.js",
    "queue:smoke": "bun run src/queue-smoke.ts",
    "check-types": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@obsr/ai": "*",
    "@obsr/db": "*",
    "@obsr/resolving": "*",
    "@obsr/sandbox": "*",
    "@obsr/types": "*",
    "@obsr/webhook-dispatch": "*",
    "hono": "^4.7.4",
    "jose": "^6.0.10",
    "zod": "^3.25.34"
  },
  "devDependencies": {
    "@obsr/typescript-config": "*",
    "@e2b/code-interpreter": "^2.3.3",
    "@types/node": "^25.0.3",
    "typescript": "^5.9.3",
    "vitest": "^4.0.16"
  }
}
