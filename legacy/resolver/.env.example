# Resolver service environment variables

# Neon PostgreSQL
DATABASE_URL=postgresql://user:pass@host/neondb?sslmode=require

# GitHub App
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=

# GitHub OAuth (observer-owned; document here for local env parity)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# AI Gateway
AI_GATEWAY_API_KEY=

# Sandbox (daytona preferred, e2b/vercel deprecated)
SANDBOX_PROVIDER=daytona
# DAYTONA_API_KEY: production API key for Daytona
DAYTONA_API_KEY=
# Optional Daytona overrides
DAYTONA_API_URL=
DAYTONA_TARGET=
DAYTONA_ORGANIZATION_ID=
DAYTONA_JWT_TOKEN=

# Legacy sandbox options
E2B_API_KEY=

# Detent app URL (for resolve result links)
APP_BASE_URL=http://detent.localhost:1355
# Legacy alias (optional)
# NAVIGATOR_BASE_URL=http://detent.localhost:1355

# Resolver queue webhook URL (must match Upstash destination)
RESOLVER_WEBHOOK_URL=http://localhost:8080/queue/resolves
# Upstash QStash signing keys for callback validation (required by queue endpoint)
QSTASH_CURRENT_SIGNING_KEY=
QSTASH_NEXT_SIGNING_KEY=
