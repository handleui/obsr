{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Detent Docs",
  "favicon": "/favicon.svg",
  "colors": {
    "primary": "#4B4B4B",
    "light": "#ffffff"
  },
  "appearance": {
    "default": "light"
  },
  "subdirectory": "docs",
  "navigation": {
    "global": {
      "anchors": [
        {
          "anchor": "Contact",
          "icon": "envelope",
          "href": "https://detent.sh/contact"
        },
        {
          "anchor": "Pricing",
          "icon": "credit-card",
          "href": "https://detent.sh/pricing"
        },
        {
          "anchor": "Status",
          "icon": "signal",
          "href": "https://status.detent.sh"
        }
      ]
    },
    "groups": [
      {
        "group": "Getting Started",
        "icon": "rocket",
        "pages": ["introduction", "quickstart", "pricing", "faq"]
      },
      {
        "group": "CLI",
        "icon": "terminal",
        "pages": ["cli/installation", "cli/heal", "cli/settings"]
      },
      {
        "group": "How It Works",
        "icon": "wand-magic-sparkles",
        "pages": [
          "cli/how-healing-works",
          "cli/tools",
          "cli/error-hints",
          "cli/budget",
          "cli/trust"
        ]
      },
      {
        "group": "CI Integration",
        "icon": "github",
        "pages": ["action/index", "cli/workflows"]
      }
    ]
  },
  "navbar": {
    "links": []
  },
  "footer": {
    "socials": {
      "github": "https://github.com/handleui/detent",
      "x": "https://x.com/handleui"
    }
  },
  "background": {
    "color": {
      "light": "#ffffff",
      "dark": "#000000"
    }
  },
  "styling": {
    "latex": false
  },
  "logo": "/images/icon_v1.png"
}
